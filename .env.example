# Copy to .env or export these variables in your shell.
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_REASONING=gemini-2.5-pro

# Optional: point the app at a running Lobster Trap reverse proxy.
# The proxy is expected to expose an OpenAI-compatible /v1/chat/completions API.
LOBSTER_TRAP_BASE_URL=http://localhost:8080/v1
LOBSTER_TRAP_ENABLED=false
LOBSTER_TRAP_API_KEY=

# Demo defaults.
HIS_DATA_PATH=data/telemetry_logs.csv
HIS_MANUALS_DIR=knowledge/manuals
HIS_AUDIT_LOG=data/audit_log.jsonl

# System Environment
LOG_LEVEL=INFO
STREAMLIT_SERVER_PORT=8501
